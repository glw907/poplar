#!/bin/sh
# Generate aerc color files from a theme.
#
# Produces:
#   generated/palette.sh         -- hex colors + ANSI tokens for Go binary
#   stylesets/<theme-name>       -- aerc styleset with hex values
#
# Usage:
#   themes/generate themes/nord.sh
#   themes/generate themes/solarized-dark.sh

set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
AERC_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

THEME="$1"
if [ -z "$THEME" ]; then
    echo "Usage: themes/generate <theme-file>" >&2
    exit 1
fi
if [ ! -f "$THEME" ]; then
    echo "Theme not found: $THEME" >&2
    exit 1
fi

# Derive theme name from filename (nord.sh -> nord)
THEME_NAME="$(basename "$THEME" .sh)"

# Source theme to get all color variables
. "$THEME"

GENERATED_DIR="$AERC_DIR/generated"
PALETTE="$GENERATED_DIR/palette.sh"
STYLESET="$AERC_DIR/stylesets/$THEME_NAME"
MARKER="# --- overrides below this line are preserved across regeneration ---"

mkdir -p "$GENERATED_DIR"
mkdir -p "$AERC_DIR/stylesets"

# Save existing overrides
save_overrides() {
    if [ -f "$1" ]; then
        sed -n "/^${MARKER}$/,\$p" "$1"
    fi
}

palette_overrides="$(save_overrides "$PALETTE")"
styleset_overrides="$(save_overrides "$STYLESET")"

# -- hex to ANSI RGB --
hex_to_ansi() {
    printf '38;2;%d;%d;%d' "0x$(echo "$1" | cut -c2-3)" "0x$(echo "$1" | cut -c4-5)" "0x$(echo "$1" | cut -c6-7)"
}

# -- Resolve markdown token --
# Input: "$COLOR_SUCCESS bold" or "bold" or "$FG_DIM"
# Output: "1;38;2;163;190;140" or "1" or "38;2;101;107;131"
resolve_token() {
    local value="$1"
    local ansi_parts=""

    for part in $value; do
        case "$part" in
            \$*)
                varname="${part#\$}"
                eval "hex=\$$varname"
                if [ -z "$hex" ]; then
                    echo "Warning: undefined variable $part in token" >&2
                    continue
                fi
                local color_ansi
                color_ansi="$(hex_to_ansi "$hex")"
                ansi_parts="${ansi_parts:+$ansi_parts;}$color_ansi"
                ;;
            bold)      ansi_parts="${ansi_parts:+$ansi_parts;}1" ;;
            italic)    ansi_parts="${ansi_parts:+$ansi_parts;}3" ;;
            underline) ansi_parts="${ansi_parts:+$ansi_parts;}4" ;;
            \#??????)
                # Bare hex color (shell expanded $VAR -> #rrggbb before we saw it)
                local color_ansi
                color_ansi="$(hex_to_ansi "$part")"
                ansi_parts="${ansi_parts:+$ansi_parts;}$color_ansi"
                ;;
            *)
                echo "Warning: unknown token part: $part" >&2
                ;;
        esac
    done
    echo "$ansi_parts"
}

# -- Write palette.sh --
cat > "$PALETTE" << 'HEADER'
# Auto-generated from theme file.
# Do not edit above the override marker -- re-generate with:
#   themes/generate themes/<theme>.sh

HEADER

cat >> "$PALETTE" << EOF
# -- Theme colors (hex) --
BG_BASE=$BG_BASE
BG_ELEVATED=$BG_ELEVATED
BG_SELECTION=$BG_SELECTION
BG_BORDER=$BG_BORDER
FG_BASE=$FG_BASE
FG_BRIGHT=$FG_BRIGHT
FG_BRIGHTEST=$FG_BRIGHTEST
FG_DIM=$FG_DIM
ACCENT_PRIMARY=$ACCENT_PRIMARY
ACCENT_SECONDARY=$ACCENT_SECONDARY
ACCENT_TERTIARY=$ACCENT_TERTIARY
COLOR_ERROR=$COLOR_ERROR
COLOR_WARNING=$COLOR_WARNING
COLOR_SUCCESS=$COLOR_SUCCESS
COLOR_INFO=$COLOR_INFO
COLOR_SPECIAL=$COLOR_SPECIAL

# -- Markdown tokens (ANSI) --
C_HEADING="$(resolve_token "$C_HEADING")"
C_BOLD="$(resolve_token "$C_BOLD")"
C_ITALIC="$(resolve_token "$C_ITALIC")"
C_LINK_TEXT="$(resolve_token "$C_LINK_TEXT")"
C_LINK_URL="$(resolve_token "$C_LINK_URL")"
C_RULE="$(resolve_token "$C_RULE")"
C_RESET="0"
EOF

# -- Write styleset --
cat > "$STYLESET" << EOF
#
# aerc styleset -- auto-generated from $THEME_NAME theme
# Do not edit above the override marker -- re-generate with:
#   themes/generate themes/$THEME_NAME.sh
#

*.default=true
*.normal=true

title.fg=$BG_BASE
title.bg=$ACCENT_PRIMARY
title.bold=true
header.bold=true

*error.bold=true
error.fg=$COLOR_ERROR
warning.fg=$COLOR_WARNING
success.fg=$COLOR_SUCCESS

statusline*.default=true
statusline_default.fg=$BG_BORDER
statusline_default.reverse=true
statusline_error.fg=$COLOR_ERROR
statusline_error.reverse=true
statusline_success.fg=$COLOR_SUCCESS
statusline_success.reverse=true

completion_default.fg=$FG_BASE
completion_default.bg=$BG_ELEVATED
completion_gutter.bg=$BG_ELEVATED
completion_pill.fg=$BG_BASE
completion_pill.bg=$ACCENT_PRIMARY
completion_description.fg=$FG_DIM
completion_description.dim=true

border.fg=$BG_BORDER

spinner.fg=$ACCENT_PRIMARY

stack.fg=$FG_BASE

selector_default.fg=$FG_BASE
selector_default.bg=$BG_BASE
selector_focused.fg=$BG_BASE
selector_focused.bg=$ACCENT_PRIMARY
selector_focused.bold=true
selector_chooser.fg=$FG_BASE
selector_chooser.bold=true

*.selected.bg=$BG_SELECTION

msglist_default.fg=$FG_BASE
msglist_read.fg=$FG_DIM
msglist_unread.fg=$ACCENT_TERTIARY
msglist_unread.bold=true
msglist_flagged.fg=$COLOR_WARNING
msglist_flagged.bold=true
msglist_answered.fg=$COLOR_SPECIAL
msglist_forwarded.fg=$COLOR_SPECIAL
msglist_forwarded.dim=true
msglist_deleted.fg=$FG_DIM
msglist_deleted.dim=true
msglist_marked.bg=$ACCENT_PRIMARY
msglist_marked.fg=$BG_BASE
msglist_result.fg=$COLOR_INFO
msglist_gutter.fg=$BG_BORDER
msglist_pill.fg=$BG_BASE
msglist_pill.bg=$ACCENT_PRIMARY
msglist_thread_folded.fg=$COLOR_WARNING
msglist_thread_context.fg=$FG_DIM
msglist_thread_context.dim=true
msglist_thread_orphan.fg=$FG_DIM

tab.fg=$FG_BRIGHT
tab.bg=$BG_BORDER
tab.selected.bg=$ACCENT_SECONDARY
tab.selected.fg=$BG_BASE

dirlist_default.fg=$FG_BASE
dirlist_unread.fg=$ACCENT_SECONDARY
dirlist_recent.fg=$ACCENT_SECONDARY

part_*.fg=$FG_BRIGHTEST
part_mimetype.fg=$BG_SELECTION
part_*.selected.fg=$FG_BRIGHTEST
part_filename.selected.bold=true

[viewer]
*.default=true
*.normal=true

header.fg=$ACCENT_PRIMARY
header.bold=true

quote_1.fg=$ACCENT_TERTIARY
quote_1.dim=false
quote_2.fg=$FG_DIM
quote_2.dim=false
quote_3.fg=$FG_DIM
quote_3.dim=true
quote_4.fg=$FG_DIM
quote_4.dim=true
quote_x.fg=$FG_DIM
quote_x.dim=true

signature.fg=$FG_BASE
signature.dim=true

url.fg=$ACCENT_TERTIARY
url.underline=true

diff_meta.bold=true
diff_chunk.dim=true
diff_add.fg=$COLOR_SUCCESS
diff_del.fg=$COLOR_ERROR
EOF

# -- Append overrides --
append_overrides() {
    local file="$1" overrides="$2"
    if [ -n "$overrides" ]; then
        printf '\n%s\n' "$overrides" >> "$file"
    else
        printf '\n%s\n' "$MARKER" >> "$file"
        printf '# Override any generated value here.\n' >> "$file"
    fi
}

append_overrides "$PALETTE" "$palette_overrides"
append_overrides "$STYLESET" "$styleset_overrides"

echo "Theme:    $THEME"
echo "Palette:  $PALETTE"
echo "Styleset: $STYLESET"
